#compdef cpptest

_cpptest() {
  local -a options
  options=(
    '-p[Print standard AI prompt]'
    '--prompt[Print standard AI prompt]'
    '-P[Print interactive AI prompt]'
    '--prompt-interactive[Print interactive AI prompt]'
    '-u[Update CppTest from GitHub]'
    '--update[Update CppTest from GitHub]'
    '-l[List installed compilers]'
    '--list[List installed compilers]'
    '-s[Select default compiler]'
    '--select[Select default compiler]'
    '-C[Set default compiler]:compiler:(${(f)"$(cpptest --list 2>/dev/null)"})'
    '--compiler[Set default compiler]:compiler:(${(f)"$(cpptest --list 2>/dev/null)"})'
    '-i[Do not isolate the build directory]'
    '--in-place[Do not isolate the build directory]'
    '-K[Force checker mode]'
    '--force-checker[Force checker mode]'
    '-k[Force diff mode]'
    '--force-diff[Force diff mode]'
    '-f[Skip linter]'
    '--fast[Skip linter]'
    '-F[Auto-fix]'
    '--fix[Auto-fix]'
    '-R[Remove comments]'
    '--no-comments[Remove comments]'
    '-S[Stress mode]'
    '--stress[Stress mode]'
    '-I[Interactive mode]'
    '--interactive[Interactive mode]'
    '-X[Auto-interact]'
    '--auto-interact[Auto-interact]'
    '--no-gen-config[Do not generate config]'
    '-G[Generate only]'
    '--gen-only[Generate only]'
    '-n[Do not generate]'
    '--no-gen[Do not generate]'
    '-a[Manual only]'
    '--manual[Manual only]'
    '-g[Generated only]'
    '--generated[Generated only]'
    '-w[No warnings as errors]'
    '--no-errors[No warnings as errors]'
    '-v[Show version]'
    '--version[Show version]'
    '-c[Show tidy path]'
    '--tidy[Show tidy path]'
  )

  _arguments -s -S $options
}